<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>fileTypes</key>
	<array>
		<string>ckt</string>
		<string>sp</string>
		<string>net</string>
		<string>cir</string>
		<string>mod</string>
		<string>mdl</string>
		<string>lib</string>
		<string>sub</string>
		<string>scs</string>
	</array>
	<key>name</key>
	<string>SPICE</string>
	<key>patterns</key>
	<array>
		<!-- Comments -->
		<dict>
			<key>comment</key>
			<string>SPICE line comment starting with *</string>
			<key>match</key>
			<string>^[ \t]*\*.*</string>
			<key>name</key>
			<string>comment.line.asterisk.spice</string>
		</dict>
		<dict>
			<key>comment</key>
			<string>SPECTRE/HSPICE line comment starting with //</string>
			<key>match</key>
			<string>^[ \t]*//.*</string>
			<key>name</key>
			<string>comment.line.double-slash.spice</string>
		</dict>
		<dict>
			<key>comment</key>
			<string>PSPICE/NGSPICE inline comment starting with ;</string>
			<key>begin</key>
			<string>;</string>
			<key>end</key>
			<string>$</string>
			<key>name</key>
			<string>comment.line.semicolon.spice</string>
		</dict>
		<dict>
			<key>comment</key>
			<string>NGSPICE inline comment starting with $</string>
			<key>begin</key>
			<string>\$</string>
			<key>end</key>
			<string>$</string>
			<key>name</key>
			<string>comment.line.dollar.spice</string>
		</dict>

		<!-- Strings -->
		<dict>
			<key>comment</key>
			<string>Single quoted string</string>
			<key>begin</key>
			<string>\'</string>
			<key>end</key>
			<string>\'</string>
			<key>name</key>
			<string>string.quoted.single.spice</string>
		</dict>
		<dict>
			<key>comment</key>
			<string>Double quoted string</string>
			<key>begin</key>
			<string>\"</string>
			<key>end</key>
			<string>\"</string>
			<key>name</key>
			<string>string.quoted.double.spice</string>
		</dict>

		<!-- Hierarchical Blocks (.subckt/.ends, .lib/.endl, .if/.endif, .control/.endc) -->
		<dict>
			<key>comment</key>
			<string>Subcircuit definition</string>
			<key>match</key>
			<string>^[\s]*\.(?:subckt|ends)[\s]+([\w]+)</string>
			<key>name</key>
			<string>keyword.control.subckt.spice</string>
		</dict>
		<dict>
			<key>comment</key>
			<string>Library block</string>
			<key>match</key>
			<string>^[\s]*\.(?:lib|endl)[\s]*</string>
			<key>name</key>
			<string>keyword.control.lib.spice</string>
		</dict>
		<dict>
			<key>comment</key>
			<string>Control block</string>
			<key>match</key>
			<string>^[\s]*\.(?:control|endc)[\s]*</string>
			<key>name</key>
			<string>keyword.control.block.spice</string>
		</dict>
		<dict>
			<key>comment</key>
			<string>If/Else/Endif block</string>
			<key>match</key>
			<string>^[\s]*\.(?:if|elseif|else|endif)[\s]*</string>
			<key>name</key>
			<string>keyword.control.conditional.spice</string>
		</dict>

		<!-- Spectre-Specific Keywords -->
		<dict>
			<key>comment</key>
			<string>Spectre subcircuit definition</string>
			<key>match</key>
			<string>^\s*(?:subckt|ends)\b</string>
			<key>name</key>
