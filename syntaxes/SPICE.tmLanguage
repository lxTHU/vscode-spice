			<string>^\s*options\b</string>
			<key>name</key>
			<string>keyword.control.spectre.options.spice</string>
		</dict>
		<dict>
			<key>comment</key>
			<string>Spectre temp</string>
			<key>match</key>
			<string>^\s*temp\b</string>
			<key>name</key>
			<string>keyword.control.spectre.temp.spice</string>
		</dict>
		<dict>
			<key>comment</key>
