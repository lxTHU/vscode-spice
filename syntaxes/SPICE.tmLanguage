					<key>name</key>
					<string>keyword.operator.unit.spice</string>
				</dict>
			</dict>
			<key>match</key>
			<string>(\d+\.?\d*)([eE])([+-]?\d+)([TGMKkmunpf]?[vVaAwWmMuUsSnNpPfF]?)\b</string>
		</dict>

