# VS Code extension packaging — exclude everything not needed at runtime.

# Source & build config (compiled output in out/ IS shipped)
src/
tsconfig.json
**/*.ts
node_modules/

# Test / dev artifacts
test/
.vscode/
*.sp
*.md
!README.md
!CHANGELOG.md

# Version control
.git/
.gitignore
.gitattributes

# Docs (README/CHANGELOG/LICENSE are auto-included by vsce)
docs/
# Internal notes must never ship — vendor/PDK-specific, commercially sensitive
docs/internal/

# Build output
*.vsix
