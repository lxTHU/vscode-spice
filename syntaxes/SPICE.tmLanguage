		<!-- Scientific Notation Numbers (e.g., 1.5e+09, 2.3E-12) -->
		<dict>
			<key>comment</key>
			<string>Scientific notation numbers</string>
			<key>captures</key>
			<dict>
				<key>1</key>
				<dict>
					<key>name</key>
					<string>constant.numeric.base.spice</string>
				</dict>
				<key>2</key>
				<dict>
					<key>name</key>
					<string>keyword.operator.exponent.spice</string>
				</dict>
				<key>3</key>
