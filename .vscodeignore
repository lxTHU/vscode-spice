# VS Code extension packaging — exclude everything not needed at runtime.
# Keep: package.json, language-configuration.json, syntaxes/, snippets/, icon.jpg, README.md, CHANGELOG.md, LICENSE, out/

# Source & build config (compiled output in out/ IS shipped)
src/
tsconfig.json
**/*.ts
node_modules/

# Test / dev artifacts
test/
.vscode/
*.sp
vsc-extension-quickstart.md

# Version control
.git/
.gitignore
.gitattributes

# Docs (README/CHANGELOG/LICENSE are auto-included by vsce)
docs/
# Internal notes must never ship — vendor/PDK-specific, commercially sensitive
docs/internal/

# Build output
*.vsix
